{
  "sourceLanguage": "en",
  "strings": {
    "·": {
      "comment": "A period used to separate different pieces of text.",
      "isCommentAutoGenerated": true
    },
    "%lld": {
      "comment": "A label displaying the number of credits the user has available. The argument is the number of credits.",
      "isCommentAutoGenerated": true
    },
    "%lld Games": {
      "comment": "A pluralized string describing the number of games in a pack. The argument is the number of games in the pack.",
      "isCommentAutoGenerated": true
    },
    "%lld moves": {
      "localizations": {
