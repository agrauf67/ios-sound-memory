    "Cards are identified only by their spoken word. This is the classic Sound Memory mode.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Karten werden nur durch das gesprochene Wort erkannt. Dies ist der klassische Sound Memory Modus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las cartas se identifican solo por su palabra hablada. Este es el modo clásico de Sound Memory."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les cartes sont identifiées uniquement par leur mot prononcé. C'est le mode classique de Sound Memory."
          }
        }
      }
    },
    "Cards play the spoken word and show the image when flipped.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Karten spielen das gesprochene Wort und zeigen das Bild beim Umdrehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las cartas reproducen la palabra hablada y muestran la imagen al voltearlas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les cartes diffusent le mot et affichent l'image une fois retournées."
          }
        }
      }
    },
    "Cards show an image when flipped. No speech is played.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Karten zeigen ein Bild beim Umdrehen. Keine Sprachausgabe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las cartas muestran una imagen al voltearlas. No se reproduce voz."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les cartes affichent une image une fois retournées. Aucune parole n'est diffusée."
          }
        }
      }
    },
