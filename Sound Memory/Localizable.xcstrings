    "Tap a card to flip it and hear the word": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf eine Karte, um sie umzudrehen und das Wort zu hören"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca una carta para voltearla y escuchar la palabra"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez une carte pour la retourner et entendre le mot"
          }
        }
      }
    },
    "Tap a second card — do they sound the same?": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf eine zweite Karte — klingen sie gleich?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca una segunda carta — ¿suenan igual?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez une deuxième carte — sonnent-elles pareil ?"
          }
        }
      }
    },
    "Tap another face-down card. Listen carefully — does it sound the same as the first card?": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf eine weitere verdeckte Karte. Hör genau hin — klingt sie genauso wie die erste Karte?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca otra carta boca abajo. Escucha con atención — ¿suena igual que la primera carta?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez une autre carte face cachée. Écoutez bien — sonne-t-elle comme la première carte ?"
          }
        }
      }
    },
    "Tap any face-down card to flip it. Depending on the game mode, you will hear the word spoken aloud, see an image, or both.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf eine verdeckte Karte, um sie umzudrehen. Je nach Spielmodus hörst du das Wort, siehst ein Bild oder beides."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca cualquier carta boca abajo para voltearla. Según el modo de juego, escucharás la palabra, verás una imagen, o ambos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez une carte face cachée pour la retourner. Selon le mode de jeu, vous entendrez le mot, verrez une image, ou les deux."
          }
        }
      }
    },
    "Tap cards to flip them and hear a word. Find the matching pair by listening for the same sound. Match all 12 pairs to win!": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf Karten, um sie umzudrehen und ein Wort zu hören. Finde das passende Paar, indem du auf den gleichen Klang achtest. Finde alle 12 Paare, um zu gewinnen!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca las cartas para voltearlas y escuchar una palabra. Encuentra la pareja escuchando el mismo sonido. ¡Encuentra las 12 parejas para ganar!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez les cartes pour les retourner et entendre un mot. Trouvez la paire correspondante en écoutant le même son. Trouvez les 12 paires pour gagner !"
          }
        }
      }
    },
    "Tap cards to hear words spoken aloud. Find the matching pair by listening for the same sound.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf Karten, um Wörter zu hören. Finde das passende Paar, indem du auf den gleichen Klang achtest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca las cartas para escuchar palabras. Encuentra la pareja escuchando el mismo sonido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez les cartes pour entendre les mots. Trouvez la paire correspondante en écoutant le même son."
          }
        }
      }
    },
    "Tap the restart icon (circular arrow) in the top bar of the play screen to shuffle and restart the current game.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf das Neustart-Symbol (kreisförmiger Pfeil) in der oberen Leiste des Spielbildschirms, um das aktuelle Spiel neu zu mischen und neu zu starten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el icono de reinicio (flecha circular) en la barra superior de la pantalla de juego para mezclar y reiniciar la partida actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez l'icône de redémarrage (flèche circulaire) dans la barre supérieure de l'écran de jeu pour mélanger et redémarrer la partie."
          }
        }
      }
    },
