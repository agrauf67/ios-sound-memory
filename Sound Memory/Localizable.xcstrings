    "Buy game packs to unlock new game sets. Use your credits to choose which games to unlock.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaufe Spielepakete, um neue Spiele freizuschalten. Verwende deine Credits, um Spiele auszuwählen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compra paquetes para desbloquear nuevos juegos. Usa tus créditos para elegir qué juegos desbloquear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Achetez des packs pour débloquer de nouveaux jeux. Utilisez vos crédits pour choisir les jeux."
          }
        }
      }
    },
    "Cancel": {
      "comment": "The text for a button that dismisses an alert.",
      "isCommentAutoGenerated": true
    },
