    "12 moves or fewer = 3 stars": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "12 Züge oder weniger = 3 Sterne"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "12 movimientos o menos = 3 estrellas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "12 coups ou moins = 3 étoiles"
          }
