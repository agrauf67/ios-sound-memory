          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld coups"
          }
        }
      }
    },
    "%lld.": {
      "comment": "A stat row in the leaderboard section of the stats screen. The argument is the row label, the second is the value for that label.",
      "isCommentAutoGenerated": true
    },
    "%lld%%": {
      "comment": "A label displaying the accuracy of a game. The value is a percentage.",
      "isCommentAutoGenerated": true
    },
