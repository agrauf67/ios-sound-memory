    "A memory card game where you match pairs by listening to sounds instead of looking at pictures!": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Memory-Spiel, bei dem du Paare durch Zuhören statt durch Bilder findest!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Un juego de memoria donde emparejas cartas escuchando sonidos en lugar de mirar imágenes!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un jeu de mémoire où vous associez des paires en écoutant des sons au lieu de regarder des images !"
          }
        }
      }
    },
    "A memory card game where you match pairs by listening to sounds instead of looking at pictures. Train your memory and learn new words in German, English, French, and Spanish!": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Memory-Spiel, bei dem du Paare durch Zuhören statt durch Bilder findest. Trainiere dein Gedächtnis und lerne neue Wörter auf Deutsch, Englisch, Französisch und Spanisch!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un juego de memoria donde emparejas cartas escuchando sonidos. ¡Entrena tu memoria y aprende palabras nuevas en alemán, inglés, francés y español!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un jeu de mémoire où vous associez des paires en écoutant des sons. Entraînez votre mémoire et apprenez de nouveaux mots en allemand, anglais, français et espagnol !"
          }
        }
      }
    },
    "Are you sure you want to spend 1 credit to unlock this game?": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchtest du wirklich 1 Credit ausgeben, um dieses Spiel freizuschalten?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que quieres gastar 1 crédito para desbloquear este juego?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment dépenser 1 crédit pour débloquer ce jeu ?"
          }
        }
      }
    },
