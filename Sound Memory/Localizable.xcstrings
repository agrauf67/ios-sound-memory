    "Statistics track your lifetime performance including games played, average moves, win streak, accuracy, and best scores per game with star ratings.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Statistiken zeigen deine Gesamtleistung: gespielte Spiele, durchschnittliche Züge, Siegesserie, Genauigkeit und beste Ergebnisse pro Spiel mit Sternebewertungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las estadísticas muestran tu rendimiento: partidas jugadas, movimientos promedio, racha de victorias, precisión y mejores puntuaciones por juego con estrellas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
